{
	"name": "projectbook",
	"private": true,
	"version": "0.5.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "node scripts/build-target.mjs vercel",
		"build:vercel": "node scripts/build-target.mjs vercel",
		"build:node": "node scripts/build-target.mjs node",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check:contracts": "node scripts/check-api-contracts.mjs",
		"check:call-budgets": "node scripts/check-route-call-budgets.mjs",
		"check:seo": "node scripts/check-seo.mjs",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"lint:secrets": "node scripts/lint-secrets.mjs",
		"check": "node scripts/check-route-call-budgets.mjs && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.22.0",
		"@internationalized/date": "^3.10.1",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-node": "^5.3.2",
		"@sveltejs/adapter-vercel": "5.0.0",
		"@sveltejs/kit": "^2.53.3",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"eslint": "^9.22.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"layerchart": "2.0.0-next.43",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.1.0",
		"svelte": "^5.53.5",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^7.2.6",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@node-rs/argon2": "^2.0.2",
		"sveltekit-superforms": "^2.29.1",
		"zod": "^4.3.6"
	}
}
