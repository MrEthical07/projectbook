# Backend API
PROJECTBOOK_API_BASE_URL=http://localhost:8080/api/v1
API_URL=http://localhost:8080
# Backend CORS reminder (set in Backend/.env):
# allowedOrigins should include your web origin, for example http://localhost:5173
# denyOrigins is optional and can block specific origins even during local development

# Google Tag Manager container ID (public)
PUBLIC_GTM_ID=

# Public site URL used in meta tags and links
PUBLIC_PROJECTBOOK_SITE_URL=http://localhost:5173
